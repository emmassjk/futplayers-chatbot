# ─────────────────────────────────────────────
# COPIA ESTE ARCHIVO A .env Y RELLENA TUS VALORES
# cp .env.example .env
# ─────────────────────────────────────────────

# GitHub Models API (obtenla en https://github.com/settings/tokens)
GITHUB_TOKEN=pon_tu_token_aqui

# Endpoint de GitHub Models (no cambiar)
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# Modelo a usar (opciones: gpt-4o-mini, gpt-4o, Phi-3-medium-128k-instruct)
LLM_MODEL=gpt-4o-mini
